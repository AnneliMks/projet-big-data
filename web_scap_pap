import time
import random
import csv
import re
import os
from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.chrome.options import Options
from webdriver_manager.chrome import ChromeDriverManager
from selenium.webdriver.chrome.service import Service

# --- CONFIG ---
OUTPUT = "pap_lyon_direct.csv"
MAX_PAGES = 15 # Tu peux monter à 15 ou 20

def get_driver():
    options = Options()
    # options.add_argument("--headless=new") # Décommente pour ne plus voir la fenêtre
    options.add_argument("--disable-blink-features=AutomationControlled")
    service = Service(ChromeDriverManager().install())
    driver = webdriver.Chrome(service=service, options=options)
    return driver

def clean_text(text):
    if not text: return ""
    # Enlève les sauts de ligne et les virgules pour ne pas casser le CSV
    return text.replace("\n", " ").replace(",", " ").strip()

# --- MAIN ---
driver = get_driver()
annonces_data = []

try:
    for page in range(1, MAX_PAGES + 1):
        url = "https://www.pap.fr/annonce/vente-appartement-maison-rhone-69-g433" if page == 1 \
        else f"https://www.pap.fr/annonce/vente-appartement-maison-rhone-69-g433-{page}"
        
        print(f"Scraping Page {page}...")
        driver.get(url)
        time.sleep(random.uniform(4, 6)) # Sécurité anti-bot

        # On cible chaque "bloc" d'annonce sur la page
        cartes = driver.find_elements(By.CLASS_NAME, "search-list-item-alt")

        for carte in cartes:
            try:
                # 1. Prix (On cherche l'élément interne)
                prix_brut = carte.find_element(By.CLASS_NAME, "item-price").text
                prix = re.sub(r"[^\d]", "", prix_brut) # On ne garde que les chiffres

                # 2. Titre / Ville
                titre = clean_text(carte.find_element(By.CLASS_NAME, "h1").text)
                
                # 3. Détails (Pièces, Surface)
                # Sur la liste, ils sont dans 'item-tags'
                details = clean_text(carte.find_element(By.CLASS_NAME, "item-tags").text)

                if prix: # On n'ajoute que si on a un prix (évite les pubs)
                    annonces_data.append({
                        "titre": titre,
                        "prix": prix,
                        "details": details
                    })
            except:
                continue # Si c'est une pub ou une erreur, on passe à la suivante

    # --- SAUVEGARDE ---
    if annonces_data:
        with open(OUTPUT, "w", newline="", encoding="utf-8-sig") as f:
            writer = csv.DictWriter(f, fieldnames=["titre", "prix", "details"])
            writer.writeheader()
            writer.writerows(annonces_data)
        print(f"\n✅ Terminé ! {len(annonces_data)} annonces enregistrées dans {OUTPUT}")

finally:
    driver.quit()